// =============================================================================
// Niri 主配置 — 手写维护, 通过 mkOutOfStoreSymlink 链接
// =============================================================================
// DMS 生成的配置文件在 dms/ 子目录, 由 `dms setup` 管理。
// 用户自定义快捷键写在本文件末尾的"用户覆盖"区域。
// =============================================================================

input {
    keyboard {
        xkb_layout "cn"                     // 键盘布局: 中文
        repeat-delay 600                    // 按键重复延迟 (ms)
        repeat-rate 25                      // 按键重复速率
        track-layout "global"              // 全局键盘布局
    }
    touchpad {
        tap                                 // 轻触点击
        natural-scroll                      // 自然滚动
    }
}

// ---- 截图存放路径 ----
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// ---- DMS 生成的配置文件 ----
// 首次启动后运行 `dms setup` 生成, 之后修改 DMS 设置后重新运行
include "dms/alttab.kdl"
include "dms/binds.kdl"
include "dms/colors.kdl"
include "dms/cursor.kdl"
include "dms/layout.kdl"
include "dms/outputs.kdl"
include "dms/windowrules.kdl"
include "dms/wpblur.kdl"

// =============================================================================
// 用户自定义快捷键 (覆盖 DMS 默认值)
// =============================================================================

// ---- 终端: kitty ----
Mod+Return { spawn "kitty"; }

// ---- 启动器: fuzzel ----
Mod+D { spawn "fuzzel"; }
